# AIGCS 服务端配置
# 复制此文件为 .env 并根据实际情况修改
#
# 优先级：compose.yml environment 块 > .env.local > .env > 默认值
# .env 和 .env.local 中的变量会被 compose.yml 的 ${VAR:-default} 语法读取

# ── 服务 ──
PORT=41905

# ── 数据库 ──
# SQLite (Docker 默认):
DATABASE_URL=file:./data/aigcs.db
# MySQL:
# DATABASE_URL=mysql://user:password@host:3306/aigcs
# PostgreSQL:
# DATABASE_URL=postgres://user:password@host:5432/aigcs

# ── JWT ──
# 请修改为随机字符串，用于 JWT 签名
JWT_SECRET=change-me-to-a-random-string

# ── 加密 (可选) ──
# 用于加密 API 密钥、SMTP 密码、TOTP 密钥的 AES-256-GCM 密钥
# 如未设置，将使用 JWT_SECRET 作为替代
# ENCRYPTION_KEY=your-encryption-key-change-me

# ── 速率限制 ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# ── SMTP (可选) ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-password
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=AIGCS

# ── 验证码 (可选) ──
# CAPTCHA_PROVIDER=turnstile
# TURNSTILE_SITE_KEY=1x00000000000000000000aa
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000aa
# RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# GEETEST_CAPTCHA_ID=your-geetest-id
# GEETEST_CAPTCHA_KEY=your-geetest-key
# CAP_SITE_KEY=your-cap-site-key
# CAP_SECRET_KEY=your-cap-secret-key
# CAP_VERIFY_URL=https://captcha.example.com/verify
# ALTCHA_SITE_KEY=your-altcha-site-key
# ALTCHA_SECRET_KEY=your-altcha-secret-key
# HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000000
# HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# ── CORS (可选) ──
# 允许跨域的来源，JSON 数组格式
# ALLOWED_ORIGINS=["https://example.com","https://blog.example.com"]

# ── 其他 (可选) ──
# REGISTRATION_OPEN=true
# GLOBAL_SYSTEM_PROMPT=你是一个专业的评论者。
# ADMIN_URL=http://localhost:5173