{
  "name": "@aigcs/widget",
  "version": "1.0.11",
  "type": "module",
  "main": "./dist/aigcs.js",
  "files": [
    "dist",
    "scripts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openaigcs/aigcs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.config.lite.ts && node scripts/extract-css.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "marked": "^18.0.5"
  }
}
